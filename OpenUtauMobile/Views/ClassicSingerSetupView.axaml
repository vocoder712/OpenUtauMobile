<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:OpenUtauMobile.ViewModels"
             xmlns:theme="clr-namespace:OpenUtauMobile.Themes.OpenUtauMobile.Runtime"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             xmlns:tools="clr-namespace:OpenUtauMobile.Tools"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OpenUtauMobile.Views.ClassicSingerSetupView"
             x:DataType="vm:ClassicSingerSetupViewModel">

    <UserControl.Resources>
        <tools:EncodingNameConverter x:Key="EncodingNameConverter" />
    </UserControl.Resources>

    <!-- TODO: 不够美观，且不应该让整个页面滚动 -->
    <Panel Background="{DynamicResource Sem.Color.Surface}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <!-- 主内容区 - 四步向导 -->
        <DockPanel x:Name="WizardPanel" IsVisible="{Binding !ShowProgressState}" VerticalAlignment="Stretch"
                   HorizontalAlignment="Stretch">
            <!-- 顶栏 -->
            <Border DockPanel.Dock="Top" Classes="TopBar">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Button Grid.Column="0"
                            Classes="TopBarBtn"
                            Command="{Binding BackCommand}"
                            ToolTip.Tip="{DynamicResource Common.Back}"
                            Content="{iconPacks:PhosphorIcons ArrowLeft}" />
                    <TextBlock Grid.Column="1"
                               Classes="TopBarTitle"
                               Text="{DynamicResource SingerSetup.Title}" />
                    <!-- 步骤指示器 -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding StepText}"
                               FontSize="12"
                               Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- Carousel - 四步内容 -->
            <Carousel x:Name="WizardCarousel"
                      SelectedIndex="{Binding Step}"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch">
                <Carousel.PageTransition>
                    <PageSlide Duration="{x:Static theme:ThemeBaseMotionTokens.DurationMedium1}" />
                </Carousel.PageTransition>

                <!-- Step 0: 压缩包编码 -->
                <Grid Background="{DynamicResource Sem.Color.Surface}"
                      Height="{Binding Bounds.Height, ElementName=WizardCarousel}"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch"
                      RowDefinitions="Auto,*,Auto">

                    <!-- 标题 -->
                    <StackPanel Grid.Row="0" Margin="16" Spacing="8">
                        <TextBlock Text="{DynamicResource SingerSetup.Step1.Title}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="{DynamicResource SingerSetup.Step1.Desc}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- 编码选择 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border
                            Background="{DynamicResource Sem.Color.SurfaceContainerLow}"
                            Padding="16" Margin="0">
                            <StackPanel Spacing="12">
                                <!-- 选项 -->
                                <TextBlock Text="{DynamicResource SingerSetup.Step1.ArchiveEncoding}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                <ComboBox ItemsSource="{Binding Encodings}"
                                          SelectedItem="{Binding ArchiveEncoding}"
                                          Width="300"
                                          HorizontalAlignment="Left">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Text="{Binding Converter={StaticResource EncodingNameConverter}, Mode=OneWay}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <!-- 预览 -->
                                <TextBlock Text="{DynamicResource SingerSetup.Step1.Preview}"
                                           FontSize="12" Margin="0,12,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}" />
                                <ListBox ItemsSource="{Binding TextItems}"
                                         Background="{DynamicResource Sem.Color.Surface}"
                                         CornerRadius="4"
                                         BorderThickness="1"
                                         BorderBrush="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                         Padding="8">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="11"
                                                       FontFamily="Courier New"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- 底部按钮 -->
                    <Border Grid.Row="2" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                <Button Classes="Primary"
                                        Content="{DynamicResource Common.Next}"
                                        Command="{Binding NextCommand}"
                                        Padding="16,8"
                                        CornerRadius="8" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Step 1: 文本编码 -->
                <Grid Background="{DynamicResource Sem.Color.Surface}"
                      Height="{Binding Bounds.Height, ElementName=WizardCarousel}"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch"
                      RowDefinitions="Auto,*,Auto">

                    <!-- 标题 -->
                    <StackPanel Grid.Row="0" Margin="16" Spacing="8">
                        <TextBlock Text="{DynamicResource SingerSetup.Step2.Title}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="{DynamicResource SingerSetup.Step2.Desc}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- 编码选择 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Background="{DynamicResource Sem.Color.SurfaceContainerLow}"
                                Padding="16" Margin="0">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{DynamicResource SingerSetup.Step2.TextEncoding}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                <ComboBox ItemsSource="{Binding Encodings}"
                                          SelectedItem="{Binding TextEncoding}"
                                          Width="300"
                                          HorizontalAlignment="Left">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Text="{Binding Converter={StaticResource EncodingNameConverter}, Mode=OneWay}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="{DynamicResource SingerSetup.Step2.Preview}"
                                           FontSize="12" Margin="0,12,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}" />
                                <ListBox ItemsSource="{Binding TextItems}"
                                         Background="{DynamicResource Sem.Color.Surface}"
                                         CornerRadius="4"
                                         BorderThickness="1"
                                         BorderBrush="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                         Padding="8">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="11"
                                                       FontFamily="Courier New"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- 底部按钮 -->
                    <Border Grid.Row="2" Padding="16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Button Grid.Column="0"
                                    Classes="Secondary"
                                    Content="{DynamicResource Common.Previous}"
                                    Command="{Binding BackCommand}"
                                    Padding="16,8"
                                    CornerRadius="8" />
                            <Button Grid.Column="2"
                                    Classes="Primary"
                                    Content="{DynamicResource Common.Next}"
                                    Command="{Binding NextCommand}"
                                    Padding="16,8"
                                    CornerRadius="8" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Step 2: 歌手类型 -->
                <Grid Background="{DynamicResource Sem.Color.Surface}"
                      Height="{Binding Bounds.Height, ElementName=WizardCarousel}"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch"
                      RowDefinitions="Auto,*,Auto">

                    <!-- 标题 -->
                    <StackPanel Grid.Row="0" Margin="16" Spacing="8">
                        <TextBlock Text="{DynamicResource SingerSetup.Step3.SingerType}"
                                   FontSize="16" FontWeight="SemiBold"
                                   IsVisible="{Binding MissingInfo}" />
                        <TextBlock Text="{DynamicResource SingerSetup.Step3.ManualDesc}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding MissingInfo}" />

                        <TextBlock Text="{DynamicResource SingerSetup.Step3.SingerInfo}"
                                   FontSize="16" FontWeight="SemiBold"
                                   IsVisible="{Binding !MissingInfo}" />
                        <TextBlock Text="{DynamicResource SingerSetup.Step3.AutoDesc}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !MissingInfo}" />
                    </StackPanel>

                    <!-- 内容 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Background="{DynamicResource Sem.Color.SurfaceContainerLow}"
                                Padding="16" Margin="0">
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0"
                                               Text="{DynamicResource SingerSetup.Step3.SingerType}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding SingerTypes}"
                                              SelectedItem="{Binding SingerType}"
                                              Width="200"
                                              HorizontalAlignment="Left" />
                                </Grid>

                                <Border BorderThickness="1"
                                        BorderBrush="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                        CornerRadius="4"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource SingerSetup.Step3.TypeHelp}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                        <TextBlock Text="{DynamicResource SingerSetup.Step3.TypeUtau}"
                                                   FontSize="11" TextWrapping="Wrap" />
                                        <TextBlock Text="{DynamicResource SingerSetup.Step3.TypeEnunu}"
                                                   FontSize="11" TextWrapping="Wrap" />
                                        <TextBlock Text="{DynamicResource SingerSetup.Step3.TypeDiffSinger}"
                                                   FontSize="11" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- 底部按钮 -->
                    <Border Grid.Row="2" Padding="16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Button Grid.Column="0"
                                    Classes="Secondary"
                                    Content="{DynamicResource Common.Previous}"
                                    Command="{Binding BackCommand}"
                                    Padding="16,8"
                                    CornerRadius="8" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                                <Button Classes="Primary"
                                        Content="{DynamicResource Common.Next}"
                                        Command="{Binding NextCommand}"
                                        Padding="16,8"
                                        CornerRadius="8" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Step 3: 安装摘要 -->
                <Grid Background="{DynamicResource Sem.Color.Surface}"
                      Height="{Binding Bounds.Height, ElementName=WizardCarousel}"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch"
                      RowDefinitions="Auto,*,Auto">

                    <!-- 标题 -->
                    <StackPanel Grid.Row="0" Margin="16" Spacing="8">
                        <TextBlock Text="{DynamicResource SingerSetup.Step4.Title}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="{DynamicResource SingerSetup.Step4.Desc}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- 安装摘要信息 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Background="{DynamicResource Sem.Color.SurfaceContainerLow}"
                                Padding="16" Margin="0">
                            <StackPanel Spacing="16">
                                <!-- 文件信息 -->
                                <Border BorderThickness="1"
                                        BorderBrush="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                        CornerRadius="4"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource SingerSetup.Step4.FileInfo}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                        <TextBlock FontSize="11" TextWrapping="Wrap">
                                            <Run Text="{DynamicResource SingerSetup.Step4.File}" />
                                            <Run Text="{Binding ArchiveFilePath}"
                                                 Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- 编码信息 -->
                                <Border BorderThickness="1"
                                        BorderBrush="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                        CornerRadius="4"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource SingerSetup.Step4.EncodingInfo}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                        <TextBlock FontSize="11">
                                            <Run Text="{DynamicResource SingerSetup.Step4.ArchiveEncoding}" />
                                            <Run
                                                Text="{Binding ArchiveEncoding, Converter={StaticResource EncodingNameConverter}, Mode=OneWay}"
                                                Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                        </TextBlock>
                                        <TextBlock FontSize="11">
                                            <Run Text="{DynamicResource SingerSetup.Step4.TextEncoding}" />
                                            <Run
                                                Text="{Binding TextEncoding, Converter={StaticResource EncodingNameConverter}, Mode=OneWay}"
                                                Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- 歌手类型 -->
                                <Border BorderThickness="1"
                                        BorderBrush="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                        CornerRadius="4"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource SingerSetup.Step4.SingerType}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                        <TextBlock FontSize="11">
                                            <Run Text="{DynamicResource SingerSetup.Step4.Type}" />
                                            <Run Text="{Binding SingerType}"
                                                 Foreground="{DynamicResource Sem.Color.OnSurface}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- 底部按钮 -->
                    <Border Grid.Row="2" Padding="16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Button Grid.Column="0"
                                    Classes="Secondary"
                                    Content="{DynamicResource Common.Previous}"
                                    Command="{Binding BackCommand}"
                                    Padding="16,8"
                                    CornerRadius="8" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                                <Button Classes="Primary"
                                        Content="{DynamicResource SingerSetup.ConfirmInstall}"
                                        Command="{Binding ConfirmInstallCommand}"
                                        Padding="16,8"
                                        CornerRadius="8" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Carousel>
        </DockPanel>

        <!-- 进度展示区 -->
        <Panel IsVisible="{Binding ShowProgressState}" Background="{DynamicResource Sem.Color.Surface}"
               VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="24"
                        Width="300">
                <!-- 进度条 -->
                <ProgressBar Value="{Binding InstallProgress}"
                             Height="6"
                             CornerRadius="3"
                             IsIndeterminate="False"
                             Background="{DynamicResource Sem.Color.SurfaceContainerLow}" />

                <!-- 进度消息 -->
                <TextBlock Text="{Binding InstallMessage}"
                           TextAlignment="Center"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}" />
            </StackPanel>
        </Panel>

        <!-- 成功状态 -->
        <Panel IsVisible="{Binding ShowSuccessState}" Background="{DynamicResource Sem.Color.Surface}"
               VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Width="300">
                <!-- 成功图标 -->
                <TextBlock Text="✓"
                           FontSize="72"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource Sem.Color.Success}"
                           FontWeight="Bold" />

                <!-- 成功标题 -->
                <TextBlock Text="{DynamicResource SingerSetup.Success}"
                           TextAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Sem.Color.OnSurface}" />

                <!-- 成功消息 -->
                <TextBlock Text="{DynamicResource SingerSetup.Success.Desc}"
                           TextAlignment="Center"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}" />

                <!-- 退出按钮 -->
                <Button Classes="Secondary"
                        Content="{DynamicResource Common.Back}"
                        Command="{Binding ExitCommand}"
                        Padding="16,12"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        Margin="0,16,0,0" />
            </StackPanel>
        </Panel>

        <!-- 错误状态 -->
        <Panel IsVisible="{Binding ShowErrorState}" Background="{DynamicResource Sem.Color.Surface}"
               VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Width="350">
                <!-- 错误图标 -->
                <TextBlock Text="✕"
                           FontSize="72"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource Sem.Color.Error}"
                           FontWeight="Bold" />

                <!-- 错误标题 -->
                <TextBlock Text="{DynamicResource SingerSetup.Failed}"
                           TextAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Sem.Color.OnSurface}" />

                <!-- 错误消息 -->
                <Border BorderThickness="1"
                        BorderBrush="{DynamicResource Sem.Color.Error}"
                        CornerRadius="4"
                        Padding="12"
                        Background="{DynamicResource Sem.Color.SurfaceContainerLow}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               TextAlignment="Left"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Sem.Color.Error}"
                               FontFamily="Courier New" />
                </Border>

                <!-- 退出按钮 -->
                <Button Classes="Secondary"
                        Content="{DynamicResource Common.Back}"
                        Command="{Binding ExitCommand}"
                        Padding="16,12"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        Margin="0,16,0,0" />
            </StackPanel>
        </Panel>
    </Panel>
</UserControl>