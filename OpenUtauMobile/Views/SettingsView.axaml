<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:OpenUtauMobile.ViewModels"
             xmlns:conv="clr-namespace:OpenUtauMobile.Tools"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OpenUtauMobile.Views.SettingsView"
             x:Name="Root"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Resources>
        <conv:EnumEqualConverter x:Key="EnumEqual" />
        <conv:EnumNotEqualConverter x:Key="EnumNotEqual" />
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════
         样式
         ═══════════════════════════════════════════════════════ -->
    <UserControl.Styles>
        <StyleInclude Source="/Themes/OpenUtauMobile/Styles/Views/SettingsView.axaml" />
    </UserControl.Styles>

    <!-- ═══════════════════════════════════════════════════════
         Root
         ═══════════════════════════════════════════════════════ -->
    <Panel Background="{DynamicResource Sem.Color.Surface}">
        <DockPanel>

            <!-- ── 顶栏 ─────────────────────────────── -->
            <Border DockPanel.Dock="Top" Classes="TopBar">
                <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Classes="TopBarBtn"
                            Command="{Binding BackCommand}"
                            ToolTip.Tip="{DynamicResource Common.Back}"
                            Content="{iconPacks:PhosphorIcons ArrowLeft}">
                    </Button>
                    <TextBlock Grid.Column="1" Classes="TopBarTitle" Text="{DynamicResource Settings.Title}" />
                </Grid>
            </Border>

            <!-- ── Body: NavRail (left) + Content (right) ──── -->
            <Grid ColumnDefinitions="Auto,Auto,*">

                <!-- ─── 左侧栏 ──────────────────────── -->
                <Border Grid.Column="0"
                        Background="{DynamicResource Sem.Color.SurfaceContainer}"
                        Width="{Binding NavWidth}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Width"
                                              Duration="0:0:0.2"
                                              Easing="CubicEaseInOut" />
                        </Transitions>
                    </Border.Transitions>

                    <DockPanel ClipToBounds="True">

                        <!-- ── 切换展开 ──── -->
                        <Border DockPanel.Dock="Bottom"
                                Height="1" Opacity="0.08"
                                Background="{DynamicResource Sem.Color.OnSurfaceVariant}" />
                        <Button DockPanel.Dock="Bottom"
                                Classes="NavToggle"
                                Command="{Binding ToggleNavCommand}">
                            <Grid ColumnDefinitions="64,*" MinHeight="48">
                                <Panel Grid.Column="0" Width="64">
                                    <iconPacks:PackIconPhosphorIcons Width="18" Height="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                          Kind="CaretLeft"
                                          IsVisible="{Binding IsNavExpanded}" />
                                    <iconPacks:PackIconPhosphorIcons Width="18" Height="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                          Kind="CaretRight"
                                          IsVisible="{Binding !IsNavExpanded}" />
                                </Panel>
                                <TextBlock Grid.Column="1"
                                           Text="{DynamicResource Common.CollapseRail}"
                                           FontSize="13"
                                           Opacity="0.60"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsNavExpanded}" />
                            </Grid>
                        </Button>

                        <!-- ── 栏目 ──────────────────── -->
                        <StackPanel ClipToBounds="True">

                            <!-- ── 1. EditAndBehaviour ──── -->
                            <Button Classes="NavItem"
                                    Command="{Binding SelectCategoryCommand}"
                                    CommandParameter="{x:Static vm:SettingsCategory.EditAndBehaviour}">
                                <Panel>
                                    <!-- Active left indicator bar -->
                                    <Border Width="3"
                                            CornerRadius="0,2,2,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            Background="{DynamicResource Sem.Color.Primary}"
                                            IsVisible="{Binding SelectedCategory,
                                                Converter={StaticResource EnumEqual},
                                                ConverterParameter=EditAndBehaviour}" />
                                    <!-- Active row tint -->
                                    <Border Background="{DynamicResource Sem.Color.Primary}"
                                            Opacity="0.08"
                                            IsVisible="{Binding SelectedCategory,
                                                Converter={StaticResource EnumEqual},
                                                ConverterParameter=EditAndBehaviour}" />
                                    <Grid ColumnDefinitions="64,*" MinHeight="56">
                                        <Panel Grid.Column="0" Width="64" HorizontalAlignment="Stretch">
                                            <!-- Icon bg pill (active) -->
                                            <Border Width="36" Height="36"
                                                    CornerRadius="10"
                                                    HorizontalAlignment="Center"
                                                    Background="{DynamicResource Sem.Color.Primary}"
                                                    Opacity="0.18"
                                                    IsVisible="{Binding SelectedCategory,
                                                        Converter={StaticResource EnumEqual},
                                                        ConverterParameter=EditAndBehaviour}" />
                                            <!-- Accent icon (active) -->
                                            <iconPacks:PackIconPhosphorIcons Width="22" Height="22"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource Sem.Color.Primary}"
                                                  Kind="NotePencil"
                                                  IsVisible="{Binding SelectedCategory,
                                                      Converter={StaticResource EnumEqual},
                                                      ConverterParameter=EditAndBehaviour}" />
                                            <!-- Muted icon (inactive) -->
                                            <iconPacks:PackIconPhosphorIcons Width="22" Height="22"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                                  Kind="NotePencil"
                                                  IsVisible="{Binding SelectedCategory,
                                                      Converter={StaticResource EnumNotEqual},
                                                      ConverterParameter=EditAndBehaviour}" />
                                        </Panel>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="2"
                                                    Margin="0,0,12,0"
                                                    IsVisible="{Binding IsNavExpanded}">
                                            <TextBlock Text="{DynamicResource Settings.Nav.EditAndBehaviour}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{DynamicResource Settings.Nav.EditAndBehaviour.Sub}"
                                                       FontSize="11" Opacity="0.50"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Panel>
                            </Button>

                            <!-- ── 2. RenderAndPerformance ── -->
                            <Button Classes="NavItem"
                                    Command="{Binding SelectCategoryCommand}"
                                    CommandParameter="{x:Static vm:SettingsCategory.RenderAndPerformance}">
                                <Panel>
                                    <Border Width="3"
                                            CornerRadius="0,2,2,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            Background="{DynamicResource Sem.Color.Primary}"
                                            IsVisible="{Binding SelectedCategory,
                                                Converter={StaticResource EnumEqual},
                                                ConverterParameter=RenderAndPerformance}" />
                                    <Border Background="{DynamicResource Sem.Color.Primary}"
                                            Opacity="0.08"
                                            IsVisible="{Binding SelectedCategory,
                                                Converter={StaticResource EnumEqual},
                                                ConverterParameter=RenderAndPerformance}" />
                                    <Grid ColumnDefinitions="64,*" MinHeight="56">
                                        <Panel Grid.Column="0" Width="64" HorizontalAlignment="Stretch">
                                            <Border Width="36" Height="36"
                                                    CornerRadius="10"
                                                    HorizontalAlignment="Center"
                                                    Background="{DynamicResource Sem.Color.Primary}"
                                                    Opacity="0.18"
                                                    IsVisible="{Binding SelectedCategory,
                                                        Converter={StaticResource EnumEqual},
                                                        ConverterParameter=RenderAndPerformance}" />
                                            <iconPacks:PackIconPhosphorIcons Width="22" Height="22"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource Sem.Color.Primary}"
                                                  Kind="Cpu"
                                                  IsVisible="{Binding SelectedCategory,
                                                      Converter={StaticResource EnumEqual},
                                                      ConverterParameter=RenderAndPerformance}" />
                                            <iconPacks:PackIconPhosphorIcons Width="22" Height="22"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                                  Kind="Cpu"
                                                  IsVisible="{Binding SelectedCategory,
                                                      Converter={StaticResource EnumNotEqual},
                                                      ConverterParameter=RenderAndPerformance}" />
                                        </Panel>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="2"
                                                    Margin="0,0,12,0"
                                                    IsVisible="{Binding IsNavExpanded}">
                                            <TextBlock Text="{DynamicResource Settings.Nav.RenderAndPerformance}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{DynamicResource Settings.Nav.RenderAndPerformance.Sub}"
                                                       FontSize="11" Opacity="0.50"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Panel>
                            </Button>

                            <!-- ── 3. FileAndStorage ──── -->
                            <Button Classes="NavItem"
                                    Command="{Binding SelectCategoryCommand}"
                                    CommandParameter="{x:Static vm:SettingsCategory.FileAndStorage}">
                                <Panel>
                                    <Border Width="3"
                                            CornerRadius="0,2,2,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            Background="{DynamicResource Sem.Color.Primary}"
                                            IsVisible="{Binding SelectedCategory,
                                                Converter={StaticResource EnumEqual},
                                                ConverterParameter=FileAndStorage}" />
                                    <Border Background="{DynamicResource Sem.Color.Primary}"
                                            Opacity="0.08"
                                            IsVisible="{Binding SelectedCategory,
                                                Converter={StaticResource EnumEqual},
                                                ConverterParameter=FileAndStorage}" />
                                    <Grid ColumnDefinitions="64,*" MinHeight="56">
                                        <Panel Grid.Column="0" Width="64" HorizontalAlignment="Stretch">
                                            <Border Width="36" Height="36"
                                                    CornerRadius="10"
                                                    HorizontalAlignment="Center"
                                                    Background="{DynamicResource Sem.Color.Primary}"
                                                    Opacity="0.18"
                                                    IsVisible="{Binding SelectedCategory,
                                                        Converter={StaticResource EnumEqual},
                                                        ConverterParameter=FileAndStorage}" />
                                            <iconPacks:PackIconPhosphorIcons Width="22" Height="22"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource Sem.Color.Primary}"
                                                  Kind="HardDrives"
                                                  IsVisible="{Binding SelectedCategory,
                                                      Converter={StaticResource EnumEqual},
                                                      ConverterParameter=FileAndStorage}" />
                                            <iconPacks:PackIconPhosphorIcons Width="22" Height="22"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                                  Kind="HardDrives"
                                                  IsVisible="{Binding SelectedCategory,
                                                      Converter={StaticResource EnumNotEqual},
                                                      ConverterParameter=FileAndStorage}" />
                                        </Panel>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="2"
                                                    Margin="0,0,12,0"
                                                    IsVisible="{Binding IsNavExpanded}">
                                            <TextBlock Text="{DynamicResource Settings.Nav.FileAndStorage}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{DynamicResource Settings.Nav.FileAndStorage.Sub}"
                                                       FontSize="11" Opacity="0.50"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Panel>
                            </Button>

                            <!-- ── 4. AppearanceAndLanguage ── -->
                            <Button Classes="NavItem"
                                    Command="{Binding SelectCategoryCommand}"
                                    CommandParameter="{x:Static vm:SettingsCategory.AppearanceAndLanguage}">
                                <Panel>
                                    <Border Width="3"
                                            CornerRadius="0,2,2,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            Background="{DynamicResource Sem.Color.Primary}"
                                            IsVisible="{Binding SelectedCategory,
                                                Converter={StaticResource EnumEqual},
                                                ConverterParameter=AppearanceAndLanguage}" />
                                    <Border Background="{DynamicResource Sem.Color.Primary}"
                                            Opacity="0.08"
                                            IsVisible="{Binding SelectedCategory,
                                                Converter={StaticResource EnumEqual},
                                                ConverterParameter=AppearanceAndLanguage}" />
                                    <Grid ColumnDefinitions="64,*" MinHeight="56">
                                        <Panel Grid.Column="0" Width="64" HorizontalAlignment="Stretch">
                                            <Border Width="36" Height="36"
                                                    CornerRadius="10"
                                                    HorizontalAlignment="Center"
                                                    Background="{DynamicResource Sem.Color.Primary}"
                                                    Opacity="0.18"
                                                    IsVisible="{Binding SelectedCategory,
                                                        Converter={StaticResource EnumEqual},
                                                        ConverterParameter=AppearanceAndLanguage}" />
                                            <iconPacks:PackIconPhosphorIcons Width="22" Height="22"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource Sem.Color.Primary}"
                                                  Kind="Palette"
                                                  IsVisible="{Binding SelectedCategory,
                                                      Converter={StaticResource EnumEqual},
                                                      ConverterParameter=AppearanceAndLanguage}" />
                                            <iconPacks:PackIconPhosphorIcons Width="22" Height="22"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                                  Kind="Palette"
                                                  IsVisible="{Binding SelectedCategory,
                                                      Converter={StaticResource EnumNotEqual},
                                                      ConverterParameter=AppearanceAndLanguage}" />
                                        </Panel>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Spacing="2"
                                                    Margin="0,0,12,0"
                                                    IsVisible="{Binding IsNavExpanded}">
                                            <TextBlock Text="{DynamicResource Settings.Nav.AppearanceAndLanguage}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{DynamicResource Settings.Nav.AppearanceAndLanguage.Sub}"
                                                       FontSize="11" Opacity="0.50"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Panel>
                            </Button>

                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ── Vertical divider ───────────────────── -->
                <Border Grid.Column="1"
                        Width="1"
                        Opacity="0.10"
                        Background="{DynamicResource Sem.Color.OnSurfaceVariant}" />

                <!-- ── 右侧详细设置页面 ─────────────────── -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              BringIntoViewOnFocusChange="False">
                    <Panel Margin="24,20,24,24">

                        <!-- ── 编辑与行为 ── -->
                        <StackPanel
                            IsVisible="{Binding SelectedCategory,
                            Converter={StaticResource EnumEqual},
                            ConverterParameter=EditAndBehaviour}">
                            <TextBlock Classes="CategoryTitle" Text="{DynamicResource Settings.Edit.CategoryTitle}" />

                            <!-- ── 钢琴键行为 ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="0">
                                    <!-- 上栏：行为选择 -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Classes="SectionLabel"
                                                       Text="{DynamicResource Settings.Edit.PianoKeyBehavior}" />
                                            <TextBlock Classes="PlaceholderText"
                                                       Text="{DynamicResource Settings.Edit.PianoKeyBehavior.Desc}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  MinWidth="140"
                                                  Margin="16,0,0,0"
                                                  ItemsSource="{Binding AvailablePianoKeyBehaviors}"
                                                  SelectedItem="{Binding SelectedPianoKeyBehavior, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PianoKeyBehaviorOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>

                                    <!-- 分隔线（仅 SoundFont 模式时显示） -->
                                    <Border Height="1"
                                            Margin="-20,12,-20,0"
                                            Opacity="0.08"
                                            Background="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                            IsVisible="{Binding SelectedPianoKeyBehavior.Value, 
                                                Converter={StaticResource EnumEqual},
                                                ConverterParameter=SoundFont}" />

                                    <!-- SF2 文件路径（仅 SoundFont 模式时显示） -->
                                    <StackPanel Margin="0,12,0,0"
                                                Spacing="8"
                                                IsVisible="{Binding SelectedPianoKeyBehavior.Value,
                                                    Converter={StaticResource EnumEqual},
                                                    ConverterParameter=SoundFont}">
                                        <TextBlock Classes="SectionLabel"
                                                   Text="{DynamicResource Settings.Edit.SoundFontPath}" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Border Grid.Column="0"
                                                    Background="{DynamicResource Sem.Color.SurfaceContainer}"
                                                    CornerRadius="8"
                                                    Padding="10,6"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SoundFontPath}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Opacity="0.65"
                                                           FontSize="13"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <Button Grid.Column="1"
                                                    Classes="AccentBtn"
                                                    Content="{DynamicResource Settings.Edit.SoundFontPath.Change}"
                                                    Command="{Binding ChangeSoundFontPathCommand}"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                        <!-- 加载状态提示 -->
                                        <TextBlock FontSize="12"
                                                   Opacity="0.65"
                                                   Foreground="{DynamicResource Sem.Color.Primary}"
                                                   IsVisible="{Binding IsSoundFontLoaded}"
                                                   Text="{DynamicResource Settings.Edit.SoundFontPath.Loaded}" />
                                        <TextBlock FontSize="12"
                                                   Opacity="0.65"
                                                   Foreground="{DynamicResource Sem.Color.Error}"
                                                   IsVisible="{Binding !IsSoundFontLoaded}"
                                                   Text="{DynamicResource Settings.Edit.SoundFontPath.NotLoaded}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── 走带自动翻页行为 ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="0">
                                    <!-- 行为选择 -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Classes="SectionLabel"
                                                       Text="{DynamicResource Settings.Edit.AutoScrollBehavior}" />
                                            <TextBlock Classes="PlaceholderText"
                                                       Text="{DynamicResource Settings.Edit.AutoScrollBehavior.Desc}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  MinWidth="140"
                                                  Margin="16,0,0,0"
                                                  ItemsSource="{Binding AvailableAutoScrollBehaviors}"
                                                  SelectedItem="{Binding SelectedAutoScrollBehavior, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AutoScrollBehaviorOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ── Stop Button Behavior ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="0">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Classes="SectionLabel"
                                                       Text="{DynamicResource Settings.Edit.StopButtonBehavior}" />
                                            <TextBlock Classes="PlaceholderText"
                                                       Text="{DynamicResource Settings.Edit.StopButtonBehavior.Desc}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  MinWidth="140"
                                                  Margin="16,0,0,0"
                                                  ItemsSource="{Binding AvailableStopButtonBehaviors}"
                                                  SelectedItem="{Binding SelectedStopButtonBehavior, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:StopButtonBehaviorOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ── 回放刷新率 ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{DynamicResource Settings.Edit.PlaybackRefreshRate}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PlaybackRefreshRate}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.70"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <Slider Minimum="1" Maximum="60"
                                            Value="{Binding PlaybackRefreshRate, Mode=TwoWay}"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True" />
                                    <TextBlock Classes="PlaceholderText"
                                               Text="{DynamicResource Settings.Edit.PlaybackRefreshRate.Desc}"
                                               FontSize="12" />
                                </StackPanel>
                            </Border>

                            <!-- ── 立绘显示 ── -->
                            <Border Classes="SettingCard">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Classes="SectionLabel"
                                                   Text="{DynamicResource Settings.Edit.ShowPortrait}" />
                                        <TextBlock Classes="PlaceholderText"
                                                   Text="{DynamicResource Settings.Edit.ShowPortrait.Desc}" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding ShowPortraitEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Margin="12,0,0,0"
                                                  OffContent=""
                                                  OnContent="" />
                                </Grid>
                            </Border>

                            <!-- ── 撤销步数上限 ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{DynamicResource Settings.Edit.UndoLimit}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding UndoLimit}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.70"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <Slider Minimum="10" Maximum="100"
                                            Value="{Binding UndoLimit, Mode=TwoWay}"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True" />
                                    <TextBlock Classes="PlaceholderText"
                                               Text="{DynamicResource Settings.Edit.UndoLimit.Desc}"
                                               FontSize="12" />
                                </StackPanel>
                            </Border>

                            <!-- ── 自动保存 ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{DynamicResource Settings.Edit.AutoSave}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.70"
                                                   VerticalAlignment="Center" >
                                            <Run Text="{Binding AutoSaveInterval}" />
                                            <Run Text="s" />
                                        </TextBlock>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <ToggleSwitch IsChecked="{Binding AutoSaveEnabled}"
                                                      OffContent=""
                                                      OnContent="" />
                                        <TextBlock Text="{DynamicResource Settings.Edit.AutoSave.Enabled}"
                                                   VerticalAlignment="Center"
                                                   FontSize="13" />
                                    </StackPanel>
                                    <Slider Minimum="30" Maximum="600"
                                            Value="{Binding AutoSaveInterval, Mode=TwoWay}"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="True"
                                            IsEnabled="{Binding AutoSaveEnabled}" />
                                    <TextBlock Classes="PlaceholderText"
                                               Text="{DynamicResource Settings.Edit.AutoSave.Desc}"
                                               FontSize="12" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                        <StackPanel
                            IsVisible="{Binding SelectedCategory,
                            Converter={StaticResource EnumEqual},
                            ConverterParameter=RenderAndPerformance}">
                            <TextBlock Classes="CategoryTitle" Text="{DynamicResource Settings.Render.CategoryTitle}" />

                            <!-- ── DiffSinger 推理参数 ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="16">
                                    <TextBlock Classes="SectionLabel"
                                               Text="{DynamicResource Settings.Render.DiffSingerParams}" />

                                    <!-- 音质模型步数 -->
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource Settings.Render.AcousticSteps}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DiffSingerSteps}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.70"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                        <Slider Minimum="1" Maximum="100"
                                                Value="{Binding DiffSingerSteps, Mode=TwoWay}"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True" />
                                        <TextBlock Classes="PlaceholderText"
                                                   Text="{DynamicResource Settings.Render.AcousticSteps.Desc}"
                                                   FontSize="12" />
                                    </StackPanel>

                                    <!-- 分隔线 -->
                                    <Border Height="1"
                                            Margin="-20,0,-20,0"
                                            Opacity="0.08"
                                            Background="{DynamicResource Sem.Color.OnSurfaceVariant}" />

                                    <!-- 唱法模型步数 -->
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource Settings.Render.VarianceSteps}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DiffSingerStepsVariance}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.70"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                        <Slider Minimum="1" Maximum="100"
                                                Value="{Binding DiffSingerStepsVariance, Mode=TwoWay}"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True" />
                                        <TextBlock Classes="PlaceholderText"
                                                   Text="{DynamicResource Settings.Render.VarianceSteps.Desc}"
                                                   FontSize="12" />
                                    </StackPanel>

                                    <!-- 分隔线 -->
                                    <Border Height="1"
                                            Margin="-20,0,-20,0"
                                            Opacity="0.08"
                                            Background="{DynamicResource Sem.Color.OnSurfaceVariant}" />

                                    <!-- 音高模型步数 -->
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource Settings.Render.PitchSteps}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DiffSingerStepsPitch}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.70"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                        <Slider Minimum="1" Maximum="100"
                                                Value="{Binding DiffSingerStepsPitch, Mode=TwoWay}"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True" />
                                        <TextBlock Classes="PlaceholderText"
                                                   Text="{DynamicResource Settings.Render.PitchSteps.Desc}"
                                                   FontSize="12" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── 机器学习运行器后端 ── -->
                            <Border Classes="SettingCard">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Classes="SectionLabel"
                                                   Text="{DynamicResource Settings.Render.OnnxRunner}" />
                                        <TextBlock Classes="PlaceholderText"
                                                   Text="{DynamicResource Settings.Render.OnnxRunner.Desc}" />
                                    </StackPanel>
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              VerticalAlignment="Center"
                                              MinWidth="160"
                                              Margin="16,0,0,0"
                                              ItemsSource="{Binding AvailableOnnxRunners}"
                                              SelectedItem="{Binding SelectedOnnxRunner, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:OnnxRunnerOption">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Grid.Column="1"
                                               Grid.Row="1"
                                               Margin="16,8,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource Sem.Color.Error}"
                                               IsVisible="{Binding SelectedOnnxRunner.Value,
                                                   Converter={StaticResource EnumEqual},
                                                   ConverterParameter=NNAPI}"
                                               Text="{DynamicResource Settings.Render.OnnxRunner.NnapiWarning}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <!-- ── 预渲染设置 ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="0">
                                    <!-- 预渲染开关 -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Classes="SectionLabel"
                                                       Text="{DynamicResource Settings.Render.PreRender}" />
                                            <TextBlock Classes="PlaceholderText"
                                                       Text="{DynamicResource Settings.Render.PreRender.Desc}" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      IsChecked="{Binding PreRenderEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0,0,0"
                                                      OffContent=""
                                                      OnContent="" />
                                    </Grid>

                                    <!-- 分隔线（仅预渲染开启时显示） -->
                                    <Border Height="1"
                                            Margin="-20,12,-20,0"
                                            Opacity="0.08"
                                            Background="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                            IsVisible="{Binding PreRenderEnabled}" />

                                    <!-- 线程数设置（仅预渲染开启时显示） -->
                                    <StackPanel Margin="0,12,0,0"
                                                Spacing="8"
                                                IsVisible="{Binding PreRenderEnabled}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{DynamicResource Settings.Render.ThreadCount}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding NumRenderThreads}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.70"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                        <Slider Minimum="1" Maximum="16"
                                                Value="{Binding NumRenderThreads, Mode=TwoWay}"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True" />
                                        <TextBlock Classes="PlaceholderText"
                                                   Text="{DynamicResource Settings.Render.ThreadCount.Desc}"
                                                   FontSize="12" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── 音频输出设置 ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="16">
                                    <TextBlock Classes="SectionLabel"
                                               Text="{DynamicResource Settings.Render.AudioOutput}" />

                                    <!-- 音频后端选择 -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource Settings.Render.AudioBackend}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Classes="PlaceholderText"
                                                       Text="{DynamicResource Settings.Render.AudioBackend.Desc}"
                                                       FontSize="12" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  MinWidth="140"
                                                  Margin="16,0,0,0"
                                                  ItemsSource="{Binding AvailableAudioBackends}"
                                                  SelectedItem="{Binding SelectedAudioBackend, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AudioBackendOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>

                                    <!-- 分隔线 -->
                                    <Border Height="1"
                                            Margin="-20,0,-20,0"
                                            Opacity="0.08"
                                            Background="{DynamicResource Sem.Color.OnSurfaceVariant}" />

                                    <!-- 音频设备选择 -->
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{DynamicResource Settings.Render.OutputDevice}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Classes="PlaceholderText"
                                                           Text="{DynamicResource Settings.Render.OutputDevice.Desc}"
                                                           FontSize="12" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Classes="AccentBtn"
                                                    Content="{DynamicResource Common.Refresh}"
                                                    Command="{Binding RefreshAudioDevicesCommand}"
                                                    IsEnabled="{Binding !IsRefreshingDevices}"
                                                    VerticalAlignment="Center"
                                                    Margin="16,0,0,0" />
                                        </Grid>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding AvailableAudioDevices}"
                                                  SelectedItem="{Binding SelectedAudioDevice, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AudioDeviceOption">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- 提示信息 -->
                                    <TextBlock Classes="PlaceholderText"
                                               Text="{DynamicResource Settings.Render.AudioBackend.RestartRequired}"
                                               FontSize="12"
                                               Foreground="{DynamicResource Sem.Color.Error}" />
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- ── 文件与存储 ── -->
                        <StackPanel
                            IsVisible="{Binding SelectedCategory,
                            Converter={StaticResource EnumEqual},
                            ConverterParameter=FileAndStorage}">
                            <TextBlock Classes="CategoryTitle" Text="{DynamicResource Settings.File.CategoryTitle}" />
                            <!-- ── 额外歌手路径 ── -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="0">

                                    <!-- 上栏：标题 + 副标题 + 开关 -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0"
                                                    Spacing="3"
                                                    VerticalAlignment="Center">
                                            <TextBlock Classes="SectionLabel"
                                                       Text="{DynamicResource Settings.File.AdditionalSingerPath}" />
                                            <TextBlock Classes="PlaceholderText"
                                                       Text="{DynamicResource Settings.File.AdditionalSingerPath.Desc}" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      IsChecked="{Binding AdditionalSingerPathEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0,0,0"
                                                      OffContent=""
                                                      OnContent="" />
                                    </Grid>

                                    <!-- 分隔线（仅开关开时显示） -->
                                    <Border Height="1"
                                            Margin="-20,12,-20,0"
                                            Opacity="0.08"
                                            Background="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                            IsVisible="{Binding AdditionalSingerPathEnabled}" />

                                    <!-- 下栏：路径 + 更改按钮（仅开关开时显示） -->
                                    <Grid ColumnDefinitions="*,Auto"
                                          Margin="0,12,0,0"
                                          IsVisible="{Binding AdditionalSingerPathEnabled}">
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource Sem.Color.SurfaceContainer}"
                                                CornerRadius="8"
                                                Padding="10,6"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AdditionalSingerPath}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Opacity="0.65"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <Button Grid.Column="1"
                                                Classes="AccentBtn"
                                                Content="{DynamicResource Settings.File.AdditionalSingerPath.Change}"
                                                Command="{Binding ChangeAdditionalSingerPathCommand}"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center" />
                                    </Grid>

                                </StackPanel>
                            </Border>

                            <Border Classes="SettingCard">
                                <StackPanel Spacing="0">
                                    <TextBlock Classes="SectionLabel" Text="{DynamicResource Settings.File.RenderCache}"/>
                                    <TextBlock Classes="PlaceholderText"
                                               Text="{DynamicResource Settings.File.RenderCache.Desc}"/>
                                    <Button Classes="AccentBtn"
                                            Content="{DynamicResource Settings.File.RenderCache.Clear}"
                                            Command="{Binding ClearRenderCacheCommand}"
                                            HorizontalAlignment="Left"
                                            Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ── 外观与语言 ── -->
                        <StackPanel
                            IsVisible="{Binding SelectedCategory,
                            Converter={StaticResource EnumEqual},
                            ConverterParameter=AppearanceAndLanguage}">
                            <TextBlock Classes="CategoryTitle"
                                       Text="{DynamicResource Settings.Appearance.CategoryTitle}" />
                            <!-- 主题选择卡片 -->
                            <Border Classes="SettingCard">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Classes="SectionLabel"
                                                   Text="{DynamicResource Settings.Appearance.Theme}" />
                                        <TextBlock Classes="PlaceholderText"
                                                   Text="{DynamicResource Settings.Appearance.Theme.Desc}" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" Grid.Row="0"
                                              VerticalAlignment="Center"
                                              MinWidth="160"
                                              Margin="16,0,0,0"
                                              ItemsSource="{Binding AvailableThemes}"
                                              SelectedItem="{Binding SelectedThemeOption, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ThemeOption">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <!-- 主题色选择卡片 -->
                            <Border Classes="SettingCard">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Classes="SectionLabel"
                                                       Text="{DynamicResource Settings.Appearance.ThemeColor}" />
                                            <TextBlock Classes="PlaceholderText"
                                                       Text="{DynamicResource Settings.Appearance.ThemeColor.Desc}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  MinWidth="160"
                                                  Margin="16,0,0,0"
                                                  ItemsSource="{Binding AvailableThemeColorModes}"
                                                  SelectedItem="{Binding SelectedThemeColorMode, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ThemeColorModeOption">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>

                                    <Border Height="1"
                                            Opacity="0.08"
                                            Background="{DynamicResource Sem.Color.OnSurfaceVariant}"
                                            IsVisible="{Binding IsCustomThemeColorMode}" />

                                    <StackPanel Spacing="10" IsVisible="{Binding IsCustomThemeColorMode}">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0"
                                                    Width="48"
                                                    Height="28"
                                                    CornerRadius="8"
                                                    Background="{Binding ThemeSeedPreviewBrush}"
                                                    BorderBrush="{DynamicResource Sem.Color.Outline}"
                                                    BorderThickness="1" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding ThemeSeedHexInput, Mode=TwoWay}"
                                                     Watermark="#RRGGBB"
                                                     VerticalAlignment="Center" />
                                            <Button Grid.Column="2"
                                                    Content="{DynamicResource Settings.Appearance.ThemeColor.ApplyHex}"
                                                    Command="{Binding ApplyThemeSeedHexCommand}"
                                                    Classes="AccentBtn" />
                                            <Button Grid.Column="3"
                                                    Content="{DynamicResource Settings.Appearance.ThemeColor.OpenPicker}"
                                                    Command="{Binding OpenThemeColorPickerCommand}" />
                                            <!-- <Button Grid.Column="4" -->
                                            <!--         Content="{DynamicResource Settings.Appearance.ThemeColor.ResetDefault}" -->
                                            <!--         Command="{Binding ResetThemeSeedCommand}" /> -->
                                        </Grid>

                                        <StackPanel Spacing="6">
                                            <TextBlock Classes="SectionLabel"
                                                       Text="{DynamicResource Settings.Appearance.ThemeColor.Presets}" />
                                            <ItemsControl ItemsSource="{Binding PresetSeedColors}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" ItemWidth="42"
                                                                   ItemHeight="42" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ThemeSeedPresetOption">
                                                        <Button Width="36"
                                                                Height="36"
                                                                Margin="0,0,6,6"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource Sem.Color.OutlineVariant}"
                                                                Background="{Binding Hex}"
                                                                ToolTip.Tip="{Binding DisplayName}"
                                                                Command="{Binding ApplyCommand}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="PlaceholderText"
                                                   Text="{Binding ThemeColorHint}"
                                                   IsVisible="{Binding HasThemeColorHint}" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6"
                                                    IsVisible="{Binding HasThemeColorSystemSource}">
                                            <TextBlock Classes="PlaceholderText"
                                                       Text="{DynamicResource Settings.Appearance.ThemeColor.Source}" />
                                            <TextBlock Classes="PlaceholderText"
                                                       Text="{Binding ThemeColorSystemSource}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <!-- ── 语言选择卡片 ── -->
                            <Border Classes="SettingCard">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Classes="SectionLabel"
                                                   Text="{DynamicResource Settings.Appearance.Language}" />
                                        <TextBlock Classes="PlaceholderText"
                                                   Text="{DynamicResource Settings.Appearance.Language.Desc}" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" Grid.Row="0"
                                              VerticalAlignment="Center"
                                              MinWidth="160"
                                              Margin="16,0,0,0"
                                              ItemsSource="{Binding AvailableLanguages}"
                                              SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LanguageOption">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </Border>

                        </StackPanel>

                    </Panel>
                </ScrollViewer>

            </Grid>
        </DockPanel>
    </Panel>
</UserControl>