<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:theme="clr-namespace:OpenUtauMobile.Themes.OpenUtauMobile.Runtime">
    <Style Selector="UserControl.PopupDialogRoot">
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.PopupDialogSurface">
        <Setter Property="Background" Value="{DynamicResource Sem.Color.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Sem.Color.OutlineVariant}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="CornerRadius" Value="{x:Static theme:ThemeSemShapeTokens.CornerDialog}" />
        <Setter Property="Opacity" Value="{x:Static theme:ThemeBaseOpacityTokens.LevelHigh}" />
    </Style>

    <Style Selector="Border.PopupTitleBar">
        <Setter Property="Padding" Value="{x:Static theme:ThemeSemLayoutTokens.InsetCardMedium}" />
        <Setter Property="Background" Value="{DynamicResource Sem.Color.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Sem.Color.OutlineVariant}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="TextBlock.PopupTitle">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource Sem.Color.OnSurface}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.PopupCloseBtn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{x:Static theme:ThemeSemLayoutTokens.InsetS}" />
        <Setter Property="CornerRadius" Value="{x:Static theme:ThemeSemShapeTokens.CornerButton}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.PopupCloseBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Sem.Color.SurfaceContainerLow}" />
    </Style>
    <Style Selector="Button.PopupCloseBtn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Sem.Color.SurfaceContainerHigh}" />
    </Style>
</Styles>