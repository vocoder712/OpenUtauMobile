<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ustx="clr-namespace:OpenUtau.Core.Ustx;assembly=OpenUtau.Core"
             xmlns:conv="clr-namespace:OpenUtauMobile.Tools"
             xmlns:c="clr-namespace:OpenUtauMobile.Controls"
             xmlns:theme="clr-namespace:OpenUtauMobile.Themes.OpenUtauMobile.Runtime"
             mc:Ignorable="d"
             x:Class="OpenUtauMobile.Controls.SingerList">

    <UserControl.Resources>
        <conv:SingerTypeToColorConverter x:Key="SingerTypeToColor" />
        <conv:SingerTypeToLabelConverter x:Key="SingerTypeToLabel" />
        <conv:AvatarDataToBitmapConverter x:Key="AvatarDataToBitmap" />
        <conv:NullToBoolConverter x:Key="NullToBool" />
        <conv:StringToInitialConverter x:Key="StringToInitial" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  ClipToBounds="False">
        <ItemsControl x:Name="SingerItemsControl"
                      Margin="{x:Static theme:ThemeSemLayoutTokens.InsetPageScroll}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="ustx:USinger">
                    <!-- 卡片按钮 -->
                    <Button Classes="SingerCard"
                            Margin="0,0,0,10"
                            Command="{Binding $parent[c:SingerList].SelectSingerCommand}"
                            CommandParameter="{Binding}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{DynamicResource Sem.Color.SurfaceContainer}"
                                        CornerRadius="18"
                                        ClipToBounds="True">
                                    <Panel>
                                        <Border x:Name="PressBg"
                                                Background="{DynamicResource Sem.Color.PrimaryContainer}"
                                                Opacity="0"
                                                CornerRadius="18" />
                                        <Grid ColumnDefinitions="6,16,60,*" MinHeight="76">

                                            <!-- Col 0: 彩签 -->
                                            <Border Grid.Column="0"
                                                    Background="{Binding SingerType, Converter={StaticResource SingerTypeToColor}}"
                                                    CornerRadius="18,0,0,18" />

                                            <!-- Col 2: 圆形头像 -->
                                            <Panel Grid.Column="2"
                                                   Width="48" Height="48"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center">
                                                <Ellipse Width="48" Height="48"
                                                         Fill="{Binding SingerType, Converter={StaticResource SingerTypeToColor}}"
                                                         Opacity="0.25" />
                                                <TextBlock
                                                    Text="{Binding LocalizedName, Converter={StaticResource StringToInitial}}"
                                                    FontSize="20"
                                                    FontWeight="SemiBold"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{Binding SingerType, Converter={StaticResource SingerTypeToColor}}" />
                                                <Panel
                                                    IsVisible="{Binding AvatarData, Converter={StaticResource NullToBool}}">
                                                    <Ellipse Width="48" Height="48">
                                                        <Ellipse.Fill>
                                                            <ImageBrush
                                                                Source="{Binding AvatarData, Converter={StaticResource AvatarDataToBitmap}}"
                                                                Stretch="UniformToFill" />
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Panel>
                                            </Panel>

                                            <!-- Col 3: 名字 + ID + 类型标签 -->
                                            <StackPanel Grid.Column="3"
                                                        VerticalAlignment="Center"
                                                        Spacing="2"
                                                        Margin="12,10,8,10">
                                                <TextBlock Text="{Binding LocalizedName}"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Id}"
                                                           FontSize="11"
                                                           Opacity="0.55"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border CornerRadius="4"
                                                        Padding="5,1"
                                                        HorizontalAlignment="Left"
                                                        Background="{Binding SingerType, Converter={StaticResource SingerTypeToColor}}"
                                                        Opacity="0.85"
                                                        Margin="0,2,0,0">
                                                    <TextBlock
                                                        Text="{Binding SingerType, Converter={StaticResource SingerTypeToLabel}}"
                                                        FontSize="10"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource Sem.Color.OnPrimary}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Panel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>

</UserControl>