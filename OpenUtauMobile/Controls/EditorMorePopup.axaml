<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:OpenUtauMobile.ViewModels"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="500"
             x:Class="OpenUtauMobile.Controls.EditorMorePopup"
             x:DataType="vm:EditorMoreViewModel"
             Classes="PopupDialogRoot"
             MinHeight="400">

    <Border Classes="PopupDialogSurface">
        <DockPanel>
            <!-- 标题栏 -->
            <Border Classes="PopupTitleBar"
                    DockPanel.Dock="Top">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{DynamicResource EditorMore.Title}" Classes="PopupTitle" />
                    <!-- 关闭按钮 -->
                    <Button Grid.Column="1"
                            Classes="PopupCloseBtn"
                            Command="{Binding CancelCommand}"
                            ToolTip.Tip="{DynamicResource Common.Close}">
                        <Path Width="14" Height="14"
                              Stretch="Uniform"
                              Fill="{DynamicResource Sem.Color.OnSurface}"
                              Data="M19,6.41 L17.59,5 L12,10.59 L6.41,5 L5,6.41 L10.59,12 L5,17.59 L6.41,19 L12,13.41 L17.59,19 L19,17.59 L13.41,12 Z" />
                    </Button>
                </Grid>
            </Border>

            <!-- Tab 区域 -->
            <TabControl Margin="16">
                <!-- 导出 -->
                <TabItem Header="{DynamicResource EditorMore.FileTab}">
                    <StackPanel Margin="0,16,0,0">
                        <Button Classes="ActionBtn"
                                Content="{DynamicResource EditorMore.SaveAs}"
                                Command="{Binding ConfirmCommand}">
                            <Button.CommandParameter>
                                <vm:EditorMoreAction>SaveAs</vm:EditorMoreAction>
                            </Button.CommandParameter>
                        </Button>
                    </StackPanel>
                </TabItem>
                <!-- 导入 -->
                <TabItem Header="{DynamicResource EditorMore.ImportTab}">
                    <StackPanel Margin="0,16,0,0">
                        <Button Classes="ActionBtn"
                                Content="{DynamicResource EditorMore.ImportAudio}"
                                Command="{Binding ConfirmCommand}">
                            <Button.CommandParameter>
                                <vm:EditorMoreAction>ImportAudio</vm:EditorMoreAction>
                            </Button.CommandParameter>
                        </Button>
                        <Button Classes="ActionBtn"
                                Content="{DynamicResource EditorMore.ImportMIDI}"
                                Command="{Binding ConfirmCommand}">
                            <Button.CommandParameter>
                                <vm:EditorMoreAction>ImportMidi</vm:EditorMoreAction>
                            </Button.CommandParameter>
                        </Button>
                        <Button Classes="ActionBtn"
                                Content="{DynamicResource EditorMore.ImportTrack}"
                                Command="{Binding ConfirmCommand}">
                            <Button.CommandParameter>
                                <vm:EditorMoreAction>ImportTrack</vm:EditorMoreAction>
                            </Button.CommandParameter>
                        </Button>
                    </StackPanel>
                </TabItem>
                <!-- 导出 -->
                <TabItem Header="{DynamicResource EditorMore.ExportTab}">
                    <StackPanel Margin="0,16,0,0">
                        <Button Classes="ActionBtn"
                                Content="{DynamicResource EditorMore.ExportAudio}"
                                Command="{Binding ConfirmCommand}">
                            <Button.CommandParameter>
                                <vm:EditorMoreAction>ExportAudio</vm:EditorMoreAction>
                            </Button.CommandParameter>
                        </Button>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</UserControl>